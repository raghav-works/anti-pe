# Keep source/config/docs with LF line endings
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Critical:
# LightGBM text model must stay LF.
# CRLF on Windows breaks LightGBM tree_sizes offsets.
models/lightgbm_pe_v1/model.txt text eol=lf

# Binary/package outputs
*.exe binary
*.dll binary
*.pyd binary
*.so binary
*.dylib binary
*.dat binary
*.zip binary
